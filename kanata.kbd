(defcfg
  process-unmapped-keys yes
)

(defsrc
  caps
  h j k l
  w b
  o
  1 2 3 4 5 6 7 8 9 0
  - =
)

(defalias
  hyper (layer-while-held hyper)
)

(deflayer base
  @hyper
  h j k l
  w b
  o
  1 2 3 4 5 6 7 8 9 0
  - =
)

(deflayer hyper
  _
  left down up right
  C-right C-left
  enter
  f1 f2 f3 f4 f5 f6 f7 f8 f9 f10
  f11 f12
)
